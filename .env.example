# Copy this file to .env only when your local tooling loads dotenv files.
# ASP.NET Core uses double underscores for nested configuration keys.
Firestore__ProjectId=your-google-cloud-project-id

# Prefer Application Default Credentials (ADC). If a local service-account
# file is unavoidable, keep it outside the repository and set only its path.
GOOGLE_APPLICATION_CREDENTIALS=C:\path\outside\the\repository\service-account.json
